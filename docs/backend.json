
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user game stats, wallet balance, and VIP status information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "vip": { "type": "boolean", "description": "Whether the user is currently a VIP." },
        "vipPlan": { "type": "string", "enum": ["none", "Silver", "Gold", "Diamond"], "description": "The active VIP tier." },
        "vipExpire": { "type": "number", "description": "Timestamp when VIP expires." },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "usdt": { "type": "number" }
          }
        },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "energy": { "type": "number" },
        "maxEnergy": { "type": "number" },
        "lastEnergyRegenAt": { "type": "number" },
        "adsWatched": { "type": "number" },
        "cinemaAdsWatched": { "type": "number" },
        "lifetimeAds": { "type": "number" },
        "adStreak": { "type": "number" },
        "lastAdAt": { "type": "number" },
        "lotteryEntries": { "type": "number" },
        "tasksCompleted": { "type": "number" },
        "tier": { "type": "string", "enum": ["Silver", "Gold", "Diamond", "God Elite"] },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralEarnings": { "type": "number" },
        "referrals": { "type": "array" },
        "socialTasks": { "type": "object" },
        "upgrades": { "type": "object" },
        "lastPassiveCollection": { "type": "number" },
        "boostEndTime": { "type": "number" },
        "claimedAdMilestones": { "type": "array" },
        "claimedReferralMilestones": { "type": "array" },
        "lastChestClaims": { "type": "object" },
        "lastDailyRewardAt": { "type": "number" },
        "lastCinemaClaimAt": { "type": "number" },
        "inventory": {
          "type": "object",
          "properties": {
            "spinTickets": { "type": "number" }
          }
        }
      },
      "required": ["uid", "username", "wallet", "referralCode", "vip", "vipPlan"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "A record of a user's request to withdraw funds in USDT.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "coins": { "type": "number" },
        "usdtAmount": { "type": "number" },
        "method": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "rejected"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "username", "coins", "usdtAmount", "method", "address", "status", "createdAt"]
    },
    "VIPRequest": {
      "title": "VIP Purchase Request",
      "description": "Manual crypto payment verification request for VIP status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "plan": { "type": "string", "enum": ["Silver", "Gold", "Diamond"] },
        "txHash": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "number" },
        "price": { "type": "number" }
      },
      "required": ["uid", "username", "plan", "txHash", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile document indexed by Firebase Auth UID."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "#/backend/entities/WithdrawalRequest",
      "description": "Withdrawal requests."
    },
    "/vip_requests/{requestId}": {
      "schema": "#/backend/entities/VIPRequest",
      "description": "VIP purchase verification requests."
    }
  }
}
