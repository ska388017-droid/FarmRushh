
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user game stats, wallet balance, and Telegram profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user (CNXXXXXX format)." },
        "username": { "type": "string" },
        "telegramId": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "usdt": { "type": "number" },
            "ton": { "type": "number" },
            "bnb": { "type": "number" }
          }
        },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "energy": { "type": "number" },
        "maxEnergy": { "type": "number" },
        "adsWatched": { "type": "number" },
        "tasksCompleted": { "type": "number" },
        "lastWithdrawalAt": { "type": "number" },
        "tier": { "type": "string", "enum": ["Silver", "Gold", "Diamond", "God Elite"] },
        "joinedAt": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralEarnings": { "type": "number" },
        "upgrades": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "lastPassiveCollection": { "type": "number" }
      },
      "required": ["uid", "username", "wallet", "referralCode"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "A record of a user's request to withdraw funds.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "coins": { "type": "number" },
        "method": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "completed", "rejected"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "username", "coins", "method", "address", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile document indexed by Firebase Auth UID."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "#/backend/entities/WithdrawalRequest",
      "description": "Individual withdrawal requests for administrative processing."
    }
  }
}
